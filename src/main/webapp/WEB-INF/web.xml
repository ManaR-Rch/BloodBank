<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>BloodBank</display-name>

    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <servlet>
        <servlet-name>DonneurServlet</servlet-name>
        <servlet-class>com.bloodbank.controller.DonneurServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>DonneurServlet</servlet-name>
        <url-pattern>/donneurs</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ReceveurServlet</servlet-name>
        <servlet-class>com.bloodbank.controller.ReceveurServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ReceveurServlet</servlet-name>
        <url-pattern>/receveurs</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CompatibilityServlet</servlet-name>
        <servlet-class>com.bloodbank.controller.CompatibilityServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>CompatibilityServlet</servlet-name>
        <url-pattern>/compatibility</url-pattern>
    </servlet-mapping>

</web-app>
